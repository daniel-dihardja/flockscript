{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://flockscript.audio/patch-schema.json",
  "title": "Audio Patch",
  "description": "JSON schema for the minimal device/route syntax that feeds the new worklet engine",
  "type": "object",
  "required": [
    "devices",
    "routes"
  ],
  "properties": {
    "devices": {
      "type": "array",
      "description": "List of available signal generators or sinks",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Optional device identifier used for referencing and routing"
          },
          "type": {
            "type": "string",
            "description": "Device type selector",
            "enum": [
              "osc",
              "lfo",
              "filter",
              "eq",
              "envelope",
              "sequencer",
              "output",
              "channel"
            ]
          },
          "params": {
            "type": "object",
            "description": "Device-specific parameters",
            "properties": {
              "wave": {
                "type": "string",
                "description": "Oscillator waveform",
                "enum": [
                  "sine",
                  "square",
                  "saw",
                  "sawtooth",
                  "triangle",
                  "noise"
                ],
                "default": "sine"
              },
              "frequency": {
                "type": "number",
                "description": "Oscillator frequency in Hz",
                "minimum": 0.01,
                "maximum": 20000,
                "default": 440
              },
              "gain": {
                "type": "number",
                "description": "Linear gain (0-1)",
                "minimum": 0,
                "maximum": 1,
                "default": 0.5
              },
              "depth": {
                "type": "number",
                "description": "LFO modulation depth (0-1)",
                "minimum": 0,
                "maximum": 1,
                "default": 0.5
              },
              "cutoff": {
                "type": "number",
                "description": "Filter cutoff frequency in Hz",
                "minimum": 20,
                "maximum": 20000,
                "default": 1000
              },
              "q": {
                "type": "number",
                "description": "Filter resonance (Q factor)",
                "minimum": 0.1,
                "maximum": 20,
                "default": 1
              },
              "mode": {
                "type": "number",
                "description": "Filter mode: 0=lowpass, 1=bandpass, 2=highpass (continuous crossfade)",
                "minimum": 0,
                "maximum": 2,
                "default": 0
              },
              "drive": {
                "type": "number",
                "description": "Input drive/saturation amount — higher values add analog warmth and harmonic distortion",
                "minimum": 1,
                "maximum": 8,
                "default": 1
              },
              "attack": {
                "type": "number",
                "description": "Envelope attack time in seconds",
                "minimum": 0,
                "default": 0.01
              },
              "decay": {
                "type": "number",
                "description": "Envelope decay time in seconds",
                "minimum": 0,
                "default": 0.1
              },
              "sustain": {
                "type": "number",
                "description": "Envelope sustain level (0-1)",
                "minimum": 0,
                "maximum": 1,
                "default": 0.7
              },
              "release": {
                "type": "number",
                "description": "Envelope release time in seconds",
                "minimum": 0,
                "default": 0.3
              },
              "steps": {
                "type": "array",
                "description": "Sequencer step frequencies in Hz",
                "items": {
                  "type": "number",
                  "minimum": 0
                },
                "minItems": 1
              },
              "rate": {
                "type": "number",
                "description": "Sequencer step rate in steps per second",
                "minimum": 0.01,
                "default": 4
              },
              "lowFreq": {
                "type": "number",
                "description": "EQ low shelf frequency in Hz",
                "minimum": 20,
                "maximum": 500,
                "default": 200
              },
              "lowGain": {
                "type": "number",
                "description": "EQ low shelf gain in dB (-20 to +20)",
                "minimum": -20,
                "maximum": 20,
                "default": 0
              },
              "midFreq": {
                "type": "number",
                "description": "EQ mid peaking frequency in Hz",
                "minimum": 200,
                "maximum": 8000,
                "default": 1000
              },
              "midGain": {
                "type": "number",
                "description": "EQ mid peaking gain in dB (-20 to +20)",
                "minimum": -20,
                "maximum": 20,
                "default": 0
              },
              "midQ": {
                "type": "number",
                "description": "EQ mid band Q (bandwidth). Higher Q = narrower band.",
                "minimum": 0.1,
                "maximum": 10,
                "default": 1.0
              },
              "highFreq": {
                "type": "number",
                "description": "EQ high shelf frequency in Hz",
                "minimum": 2000,
                "maximum": 20000,
                "default": 4000
              },
              "highGain": {
                "type": "number",
                "description": "EQ high shelf gain in dB (-20 to +20)",
                "minimum": -20,
                "maximum": 20,
                "default": 0
              },
              "pan": {
                "type": "number",
                "description": "Stereo pan position (-1 full left, 0 centre, +1 full right)",
                "minimum": -1,
                "maximum": 1,
                "default": 0
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "osc"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "wave": {},
                    "frequency": {},
                    "gain": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "lfo"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "wave": {},
                    "frequency": {},
                    "depth": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "filter"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "cutoff": {},
                    "q": {},
                    "mode": {},
                    "drive": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "eq"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "lowFreq": {},
                    "lowGain": {},
                    "midFreq": {},
                    "midGain": {},
                    "midQ": {},
                    "highFreq": {},
                    "highGain": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "envelope"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "attack": {},
                    "decay": {},
                    "sustain": {},
                    "release": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "sequencer"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "steps": {},
                    "rate": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "output"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "gain": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "channel"
                }
              },
              "required": [
                "type"
              ]
            },
            "then": {
              "properties": {
                "params": {
                  "properties": {
                    "gain": {},
                    "pan": {}
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        ]
      }
    },
    "routes": {
      "type": "array",
      "description": "Connections between devices",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "signal"
        ],
        "properties": {
          "from": {
            "type": "string",
            "description": "Source device channel, e.g. osc1.out"
          },
          "to": {
            "type": "string",
            "description": "Destination device channel, e.g. out.in"
          },
          "signal": {
            "type": "string",
            "description": "Signal type carried by the route",
            "enum": [
              "audio",
              "mod",
              "seq"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "devices": [
        {
          "id": "osc1",
          "type": "osc",
          "params": {
            "wave": "sine",
            "frequency": 80,
            "gain": 0.7
          }
        },
        {
          "id": "osc2",
          "type": "osc",
          "params": {
            "wave": "sine",
            "frequency": 432,
            "gain": 0.03
          }
        },
        {
          "id": "out",
          "type": "output",
          "params": {
            "gain": 1
          }
        }
      ],
      "routes": [
        {
          "from": "osc1.out",
          "to": "out.in",
          "signal": "audio"
        },
        {
          "from": "osc2.out",
          "to": "out.in",
          "signal": "audio"
        }
      ]
    }
  ]
}