{
  "name": "@workspace/audio",
  "version": "1.0.0",
  "type": "module",
  "description": "Live coding environment for experimental noise/glitch music with Web Audio API",
  "scripts": {
    "copy:faust": "mkdir -p public/faust && cp ../faust/public/filter.wasm ../faust/public/filter.json public/faust/",
    "build": "pnpm copy:faust && tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "prepare": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^7.0.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "patches",
    "public/faust",
    "worklet"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "ajv": "^8.14.1"
  }
}
