{
    "devices": [
        {
            "id": "osc1",
            "type": "osc",
            "params": {
                "wave": "sawtooth",
                "frequency": 80,
                "gain": 0.8
            }
        },
        {
            "id": "filter1",
            "type": "filter",
            "params": {
                "filterType": "highpass",
                "cutoff": 1200,
                "q": 2
            }
        },
        {
            "id": "out",
            "type": "output",
            "params": {
                "gain": 1
            }
        }
    ],
    "routes": [
        {
            "from": "osc1.out",
            "to": "filter1.in",
            "signal": "audio"
        },
        {
            "from": "filter1.out",
            "to": "out.in",
            "signal": "audio"
        }
    ]
}