{
    "devices": [
        {
            "id": "trail",
            "type": "shader",
            "params": {
                "frag": "feedbackTrail",
                "uniforms": {
                    "u_speed": {
                        "type": "float",
                        "value": 0.5
                    },
                    "u_inject_size": {
                        "type": "float",
                        "value": 0.12
                    },
                    "u_inject_bright": {
                        "type": "float",
                        "value": 1.0
                    }
                }
            }
        },
        {
            "id": "fb",
            "type": "feedback",
            "params": {
                "decay": 0.97,
                "inject": 1.0,
                "scroll_x": 0.003,
                "scroll_y": 0.002,
                "warp": 0.001,
                "warp_speed": 1.0,
                "blur": 0.0
            }
        },
        {
            "id": "display",
            "type": "screen"
        }
    ],
    "routes": [
        {
            "from": "trail.out",
            "to": "fb.in",
            "signal": "visual"
        },
        {
            "from": "fb.out",
            "to": "display.in",
            "signal": "visual"
        }
    ]
}