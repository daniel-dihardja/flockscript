{
  "theme": {
    "&": {
      "height": "100%",
      "backgroundImage": "linear-gradient(160deg, #0f172a, #1e1b4b 40%, #111827)",
      "color": "#f8fafc",
      "transition": "background 0.6s ease"
    },
    ".cm-scroller": {
      "fontFamily": "'SF Mono' 'Space Grotesk', 'JetBrains Mono', 'Fira Code', monospace",
      "fontSize": "18px",
      "lineHeight": "1.65",
      "letterSpacing": "0.015em"
    },
    ".cm-content": {
      "padding": "18px",
      "caretColor": "#f8fafc",
      "fontWeight": "500"
    },
    ".cm-selectionBackground": {
      "backgroundColor": "rgba(249, 115, 22, 0.4)"
    },
    ".cm-selection": {
      "color": "#ffffff",
      "fontWeight": "600"
    },
    ".cm-activeLine": {
      "backgroundColor": "rgba(168, 85, 247, 0.1)"
    },
    ".cm-gutters": {
      "backgroundColor": "rgba(15, 23, 42, 0.75)",
      "color": "#94a3b8",
      "borderRight": "1px solid rgba(168, 85, 247, 0.3)"
    },
    ".cm-dsl-main-keyword": {
      "color": "#fb923c",
      "fontWeight": "700"
    },
    ".cm-dsl-top-level-keyword": {
      "backgroundColor": "none",
      "color": "#facc15",
      "fontWeight": "700",
      "padding": "2px 4px",
      "borderRadius": "4px"
    },
    ".cm-dsl-osc": {
      "color": "#fb923c",
      "fontWeight": "600"
    },
    ".cm-dsl-waveform": {
      "color": "#fca5a1",
      "fontWeight": "400"
    },
    ".cm-dsl-number": {
      "color": "#fca5a5"
    },
    ".cm-dsl-name, .cm-dsl-route-source, .cm-dsl-route-target": {
      "backgroundColor": "none",
      "borderRadius": "4px",
      "padding": "2px 4px",
      "color": "#CCCCCC",
      "fontWeight": "700"
    },
    ".cm-dsl-operator": {
      "color": "#fbbf24",
      "fontWeight": "600"
    },
    ".cm-dsl-param": {
      "fontWeight": "700",
      "color": "#38bdf8"
    },
    ".cm-dsl-last-executed": {
      "backgroundColor": "rgba(251, 146, 60, 0.3)",
      "borderRadius": "3px",
      "boxShadow": "0 0 10px rgba(251, 146, 60, 0.45)"
    }
  },
  "topLevelKeywords": ["audio"],
  "mainKeywords": ["osc", "output", "silence", "sil"],
  "keywordList": [],
  "waveforms": ["sine"],
  "keywordAliases": {
    "sil": "silence"
  },
  "paramKeywords": ["frequency", "gain", "wave"],
  "regex": {
    "block": {
      "pattern": "^---.*---$",
      "flags": "gm"
    },
    "osc": {
      "pattern": "\\bosc\\b",
      "flags": "g"
    },
    "number": {
      "pattern": "(?<!\\w)[+-]?\\d+(?:\\.\\d+)?c?",
      "flags": "g"
    },
    "macro": {
      "pattern": "@macro\\([^\\)]*\\)|@\\d+(?:\\.\\d+)?",
      "flags": "g"
    },
    "operator": {
      "pattern": "->",
      "flags": "g"
    },
    "name": {
      "pattern": "(?<=\\b(?:osc|lfo|noi|noise|fx|voice|voi|env|filter|output)(?:\\s+|<))(?!(?:sin|sine|saw|sawtooth|square|sqr|triangle|tri|lowpass|lps|lp|highpass|hps|hp|bandpass|bnp|bnd|notch|ntc|nct)\\b)(?![0-9\\.])#?[A-Za-z0-9_-]+(?=(?:>|\\s|\\.|$))",
      "flags": "gi"
    },
    "routeSource": {
      "pattern": "(?<=\\broute\\s+)[A-Za-z0-9_-]+",
      "flags": "gi"
    },
    "routeTarget": {
      "pattern": "(?<=->\\s+)[A-Za-z0-9_-]+(?=\\.|\\s|$)",
      "flags": "gi"
    },
    "listName": {
      "pattern": "(?<=\\[|,\\s*)(#?[A-Za-z0-9_-]+)(?=\\s*(?:,|\\]))",
      "flags": "g"
    }
  }
}
