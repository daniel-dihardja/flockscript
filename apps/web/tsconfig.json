{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/compiler": ["../../packages/compiler/src"],
      "@workspace/compiler/*": ["../../packages/compiler/src/*"],
      "@workspace/audio": ["../../packages/audio/src/index.ts"],
      "@workspace/audio/*": ["../../packages/audio/*"],
      "@workspace/visuals": ["../../packages/visuals/src/index.ts"],
      "@workspace/visuals/*": ["../../packages/visuals/src/*"]
    },
    "allowImportingTsExtensions": true,
    "noImplicitAny": false,
    "types": ["node"],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
